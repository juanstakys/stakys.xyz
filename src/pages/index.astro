<style>
	section {
		margin: 2em 0;
	}
	.title {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 3em;
	}
	:global(.title .portrait-image) {
		width: 30vw;
		max-width: 200px;
	}
	:global(.title .portrait-image img) {
		width: 100%;
		height: auto;
	}
</style>
